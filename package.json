{
  "name": "srs-evaluation-dashboard",
  "version": "1.0.0",
  "description": "SRS Infoway Evaluation Dashboard - Full Stack Application",
  "main": "backend/server.js",
  "scripts": {
    "start": "cd backend && node server.js",
    "build": "npm run build:frontend && npm run build:backend && npm run init-db",
    "build:frontend": "cd frontend && npm install --legacy-peer-deps && npm run build",
    "build:backend": "cd backend && npm install --legacy-peer-deps --production",
    "init-db": "cd backend && npm run init-db",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "clear-db": "cd backend && npm run clear-db",
    "reset-db": "cd backend && npm run reset-db"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "multer": "^1.4.5-lts.1",
    "mammoth": "^1.6.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "evaluation",
    "dashboard",
    "react",
    "nodejs",
    "sqlite",
    "document-processing"
  ],
  "author": "SRS Infoway",
  "license": "MIT"
}